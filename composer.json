{
	"name" : "marshal/marshal",
	"description" : "Bootstrap a Marshal application",
	"type" : "library",
	"license" : "AGPL-3.0-or-later",
	"autoload" : {
		"classmap": ["apps/*/src"],
		"psr-4" : {
			"Marshal\\" : "src/"
		}
	},
	"authors" : [
		{
			"name" : "Collins Pamba",
			"email" : "collinspamba@outlook.com"
		}
	],
	"classmap-authoritative": true,
	"config" : {
		"sort-packages" : true
	},
	"minimum-stability" : "dev",
	"optimize-autoloader": true,
	"prefer-stable" : true,
	"require" : {
		"ext-intl": "*",
		"ext-mbstring": "*",
		"ext-xml": "*",
		"doctrine/dbal": "^4.4",
		"guzzlehttp/guzzle": "^7.12",
		"laminas/laminas-config-aggregator": "^1.19",
		"laminas/laminas-diactoros": "^3.8",
		"laminas/laminas-form": "^3.24",
		"laminas/laminas-httphandlerrunner": "^2.13",
		"laminas/laminas-inputfilter": "^2.35",
		"laminas/laminas-stratigility": "^4.3",
		"lcobucci/clock": "^3.6",
		"league/flysystem": "^3.33",
		"loophp/collection": "^7.6",
		"mezzio/mezzio-fastroute": "^3.14",
		"mezzio/mezzio-helpers": "^5.20",
		"mezzio/mezzio-session": "^1.17",
		"monolog/monolog": "^3.10",
		"psr/event-dispatcher": "^1.0",
		"psr7-sessions/storageless": "^10.2",
		"starfederation/datastar-php": "^1.0",
		"symfony/console": "^8.1",
		"symfony/string": "^8.1",
		"twig/twig": "^3.22"
	},
	"require-dev" : {
		"phpstan/phpstan": "^2.2",
		"phpunit/phpunit": "^13.2"
	},
	"scripts": {
        "python": [
            "Composer\\Config::disableProcessTimeout",
            ". src/Utils/Python/venv/bin/activate && python src/Utils/Python/run.py"
        ],
        "hypercorn": [
            "Composer\\Config::disableProcessTimeout",
            ". src/Utils/Python/venv/bin/activate && hypercorn src/Utils/Python/run.py"
        ]
    }
}
